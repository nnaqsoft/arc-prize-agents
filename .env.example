# ARC-AGI-3 API key — get one at https://three.arcprize.org/
ARC_API_KEY=your-arc-agi-3-api-key-here

# Anthropic API key (the agent's LLM brain).
# Leave unset if running via a Claude Code subscription / local Claude session.
ANTHROPIC_API_KEY=

# MLflow tracking URI (default = local mlruns/ dir)
MLFLOW_TRACKING_URI=file:./mlruns
